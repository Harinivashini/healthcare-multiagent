# ── Backend Dockerfile ──────────────────────────────────────────────────────
# Python 3.11 slim — minimal image with layer caching

FROM python:3.11-slim AS base

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps first (cached layer)
COPY agents/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY agents/ ./agents/
COPY data/    ./data/

# Create data dir for SQLite persistence
RUN mkdir -p /app/data

# Expose port
EXPOSE 8000

# Seed DB + start server
CMD ["sh", "-c", "python data/generate_dataset.py && uvicorn agents.main:app --host 0.0.0.0 --port 8000"]
